{
  "name": "@velvetmonkey/flywheel-memory",
  "version": "2.8.0",
  "description": "MCP tools that search, write, and auto-link your Obsidian vault — and learn from your edits.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "flywheel-memory": "bin/flywheel-memory.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velvetmonkey/flywheel-memory.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/velvetmonkey/flywheel-memory/issues"
  },
  "homepage": "https://github.com/velvetmonkey/flywheel-memory#readme",
  "author": "velvetmonkey",
  "keywords": [
    "mcp",
    "mcp-server",
    "obsidian",
    "pkm",
    "markdown",
    "knowledge-graph",
    "wikilinks",
    "backlinks",
    "vault",
    "claude",
    "claude-code",
    "local-first",
    "daily-notes",
    "zettelkasten"
  ],
  "scripts": {
    "build": "npx esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --packages=external && npx esbuild src/core/read/embedding-worker.ts --bundle --platform=node --format=esm --outfile=dist/embedding-worker.js --packages=external && npx esbuild src/core/read/integrity-worker.ts --bundle --platform=node --format=esm --outfile=dist/integrity-worker.js --packages=external && chmod +x dist/index.js",
    "dev": "npx esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --packages=external --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:read": "vitest run test/read/",
    "test:write": "vitest run test/write/",
    "test:security": "vitest run test/write/security/",
    "test:stress": "vitest run test/write/stress/ test/write/battle-hardening/",
    "test:quality": "vitest run test/graph-quality/",
    "test:quality:report": "tsx test/graph-quality/generate-proof.ts",
    "generate:tool-embeddings": "tsx scripts/generate-tool-embeddings.ts",
    "generate:doc-fragments": "tsx scripts/generate-doc-fragments.ts",
    "smoke:registry-latest": "node scripts/post-publish-codex-smoke.mjs latest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --reporter=github-actions",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "postinstall": "node -e \"['bin/flywheel-memory.js','dist/index.js'].forEach(f=>{try{require('fs').chmodSync(f,0o755)}catch{}})\"",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@velvetmonkey/vault-core": "^2.8.0",
    "better-sqlite3": "^12.0.0",
    "chokidar": "^4.0.0",
    "gray-matter": "^4.0.3",
    "simple-git": "^3.22.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.1.1",
    "esbuild": "^0.27.4",
    "fast-check": "^3.15.0",
    "mcp-testing-kit": "^0.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.2",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "Apache-2.0",
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
