{
  "name": "flywheel-memory-monorepo",
  "version": "0.0.0-private",
  "private": true,
  "description": "Persistent knowledge graph memory for AI agents. Search, read, and write tools over an Obsidian vault via MCP.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "dev": "npm run dev -w @velvetmonkey/flywheel-memory",
    "dev:fast": "FLYWHEEL_TOOLS=agent VAULT_PATH=. node packages/mcp-server/dist/index.js",
    "bench": "npm run bench -w @velvetmonkey/flywheel-bench"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velvetmonkey/flywheel-memory.git"
  },
  "author": "velvetmonkey",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=9.0.0"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "hono": "^4.12.14",
    "protobufjs": "^7.5.5",
    "fast-uri": "^3.1.2"
  },
  "devDependencies": {
    "glob": "^13.0.6",
    "typescript": "^5.3.3"
  }
}
